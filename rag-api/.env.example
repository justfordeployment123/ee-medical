# OpenAI (required for RAG)
OPENAI_API_KEY=your_openai_api_key

# Email / SMTP (optional – for sending pathway summary & checklists per document)
# If not set, leads are logged to console only
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@eemedicals.com
